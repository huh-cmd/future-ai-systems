#!/bin/sh
# ============================================================
# SECRET SCANNER — PRE-COMMIT HOOK
# Blocks any commit containing credential patterns.
# Install: copy to .git/hooks/pre-commit
# ============================================================

STAGED=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED" ] && exit 0

TMPFILE=$(mktemp)
echo "0" > "$TMPFILE"

scan_file() {
  FILE="$1"
  CONTENT=$(git show ":$FILE" 2>/dev/null) || return 0

  check() {
    LABEL="$1"
    PATTERN="$2"
    if echo "$CONTENT" | grep -qE -- "$PATTERN"; then
      echo "[SECURITY BLOCK] $LABEL detected in: $FILE"
      echo "Remove the credential before committing."
      echo "1" > "$TMPFILE"
    fi
  }

  check "OpenAI key (sk-)"              'sk-[a-zA-Z0-9_-]{20,}'
  check "Anthropic key (sk-ant-)"       'sk-ant-[a-zA-Z0-9_-]{20,}'
  check "Google API key (AIza)"         'AIza[0-9A-Za-z_-]{35}'
  check "AWS access key (AKIA)"         'AKIA[0-9A-Z]{16}'
  check "Private key header"            'BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY'
  check "api_key assignment"            'api[_-]?key\s*[=:]\s*["\x27][a-zA-Z0-9_\-]{16,}'
  check "token assignment"              'token\s*[=:]\s*["\x27][a-zA-Z0-9_\-]{20,}'
  check "secret assignment"             'secret\s*[=:]\s*["\x27][a-zA-Z0-9_\-]{16,}'
  check "ANTHROPIC_API_KEY set"         'ANTHROPIC_API_KEY\s*=\s*[^\s$]'
  check "OPENAI_API_KEY set"            'OPENAI_API_KEY\s*=\s*[^\s$]'
  check "GITHUB_TOKEN set"              'GITHUB_TOKEN\s*=\s*[^\s$]'
}

for FILE in $STAGED; do
  scan_file "$FILE"
done

FOUND=$(cat "$TMPFILE")
rm -f "$TMPFILE"

if [ "$FOUND" = "1" ]; then
  echo ""
  echo "Commit BLOCKED. Approved credential storage: C:\\Users\\jeffe\\.env.keys only."
  exit 1
fi

exit 0
